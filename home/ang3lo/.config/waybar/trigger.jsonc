{
    "layer": "top",
    "position": "top",
    "exclusive": false,
    "height": 1,
    "modules-center": ["custom/trigger"],
    "custom/trigger": {
        "format": " ",
        "tooltip": false,
        "on-scroll-up": "~/.config/waybar/scripts/waybar-toggle.sh",
        "on-scroll-down": "~/.config/waybar/scripts/waybar-toggle.sh"
    }
}
