{
    "layer": "top",
    "position": "top",
    "exclusive": false,
    "height": 1,
    "modules-center": ["custom/trigger"],
    "custom/trigger": {
        "format": " ",
        "tooltip": false,
        "on-scroll-up": "systemctl --user kill -s SIGUSR1 waybar.service",
        "on-scroll-down": "systemctl --user kill -s SIGUSR1 waybar.service"
    }
}
