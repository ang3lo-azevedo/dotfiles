{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "notification-window-preferred-output": "eDP-1",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "cssPriority": "application",
  "control-center-margin-top": 0,
  "control-center-margin-bottom": 0,
  "control-center-margin-right": 0,
  "control-center-margin-left": 0,
  "notification-inline-replies": false,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "control-center-width": 500,
  "control-center-height": 600,
  "notification-window-width": 500,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,
  "widgets": [
    "menubar#label",
    "backlight",
    "backlight#KB",
    "volume",
    "mpris",
    "title",
    "dnd",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },

    "volume": {
      "label": "󰕾",
      "show-per-app": true,
      "show-per-app-label": true
    },
    "backlight": {
      "label": "󰃞"
    },
    "backlight#KB": {
      "label": " ",
      "device": "samsung-galaxybook::kbd_backlight",
      "subsystem": "leds"
    },
    "menubar#label": {
      "buttons#touchscreen": {
        "position": "right",
        "actions": [
          {
            "label": "\udb80\uddbd",
            "command": "~/.config/waybar/scripts/touchscreen-toggle.sh toggle"
          }
        ]
      },
      "menu#powermode-buttons": {
        "label": "\uf0e4", 
        "position": "right",
        "actions": [ 
          {
            "label": "\uf0e7 Performance",
            "command": "pkexec auto-cpufreq --force performance"
          },
          {
            "label": "\uf1ce Auto",
            "command": "pkexec auto-cpufreq --force reset"
          },
          {
            "label": "\uf06c Power-saver",
            "command": "pkexec auto-cpufreq --force powersave"
          }
        ]
      },
      "menu#power-buttons": {
        "label": "", 
        "position": "right",
        "actions": [ 
          {
            "label": "\uf023 Lock Screen",
            "command": "~/.config/fuzzel/scripts/fuzzel-powermenu.sh \"Lock Screen\""
          },
          {
            "label": "\uf236 Suspend System",
            "command": "~/.config/fuzzel/scripts/fuzzel-powermenu.sh \"Suspend System\""
          },
          {
            "label": "\uf104 Log Out",
            "command": "~/.config/fuzzel/scripts/fuzzel-powermenu.sh \"Log Out\""
          },
          {
            "label": "\uf2f1 Restart System",
            "command": "~/.config/fuzzel/scripts/fuzzel-powermenu.sh \"Restart System\""
          },
          {
            "label": "\uf085 Restart to UEFI",
            "command": "~/.config/fuzzel/scripts/fuzzel-powermenu.sh \"Restart to UEFI\""
          },
          {
            "label": "\uf071 Force Restart",
            "command": "~/.config/fuzzel/scripts/fuzzel-powermenu.sh \"Force Restart\""
          },
          {
            "label": "\uf011 Shutdown System",
            "command": "~/.config/fuzzel/scripts/fuzzel-powermenu.sh \"Shutdown System\""
          }
        ]
      }
    }
  }
}